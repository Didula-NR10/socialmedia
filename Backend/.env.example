# Your OWN Supabase test project — separate from the real system's project.
ENVIRONMENT=development
PROJECT_NAME=Social Module Standalone

SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co
SUPABASE_KEY=YOUR_TEST_PROJECT_ANON_OR_SERVICE_KEY
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR-TEST-PROJECT-DB-HOST:5432/postgres

JWT_SECRET=any-long-random-string-for-local-testing
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Required by config/database.py's Settings class even though Social
# doesn't use email — keep any placeholder values so pydantic doesn't
# fail to load .env when testing standalone.
SMTP_USER=test@example.com
SMTP_PASSWORD=placeholder
SMTP_FROM_EMAIL=test@example.com

# Cloudinary free-tier account (sign up at cloudinary.com, values are on
# your dashboard's "Product Environment Credentials" panel).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
